<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KubeTunnel.Views.TextInputDialog"
        Title="Input Dialog"
        Width="300" Height="140"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Name="InputTextBox" Grid.Row="0" Margin="0,5" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="0,0,5,0" Click="OkButton_Click" />
            <Button Content="Cancel" Width="80" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
